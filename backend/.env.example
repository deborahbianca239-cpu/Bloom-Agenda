# ===== Servidor =====
NODE_ENV=development
PORT=3006
# Origens permitidas (separadas por vírgula). Use * para liberar tudo (apenas dev).
CORS_ORIGIN=*
# URL do frontend (usada nos links de recuperação de senha)
FRONTEND_URL=http://localhost:5500

# ===== PostgreSQL =====
# --- Opção A: Postgres local ---
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=sua_senha
DB_NAME=bloom_agenda
DB_SSL=false

# --- Opção B: Supabase (recomendado p/ nuvem) ---
# No painel do Supabase: Project Settings > Database > Connection string > URI.
# Use a string do "Connection pooling" (porta 6543) e troque [YOUR-PASSWORD].
# Quando DATABASE_URL existe, ela tem prioridade sobre DB_HOST/DB_USER acima.
# DATABASE_URL=postgresql://postgres.xxxx:[YOUR-PASSWORD]@aws-0-sa-east-1.pooler.supabase.com:6543/postgres
# DB_SSL=true

# ===== JWT =====
JWT_SECRET=troque-por-uma-chave-secreta-forte
JWT_EXPIRES_IN=7d
JWT_RESET_SECRET=troque-por-outra-chave-secreta
JWT_RESET_EXPIRES_IN=30m

# ===== Segurança =====
BCRYPT_ROUNDS=10

# ===== E-mail (Nodemailer) — opcional em dev =====
# Sem essas variáveis, o link de recuperação é apenas exibido no console.
MAIL_HOST=
MAIL_PORT=587
MAIL_SECURE=false
MAIL_USER=
MAIL_PASS=
MAIL_FROM=Bloom Agenda <no-reply@bloom.agenda>
